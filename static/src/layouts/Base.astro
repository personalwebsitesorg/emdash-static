---
import { getSiteSettings, getMenuItems, getPosts, getTheme } from "@site/snapshot";
import { getSiteConfig } from "@site/site-config";
import { getThemeStylesheetHref } from "@site/theme-styles";
import fontPreloads from "@generated/font-preloads.json";
import "@generated/fonts.css";

const themeStyleHref = await getThemeStylesheetHref(getTheme());

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonical?: string;
  publishedAt?: string | null;
  updatedAt?: string | null;
  currentPath?: string;
}

const {
  title: pageTitle,
  description = "",
  ogImage = "",
  ogType = "website",
  canonical,
  publishedAt,
  updatedAt,
  currentPath,
} = Astro.props;

const settings = getSiteSettings();
const config = getSiteConfig();
const menuItems = getMenuItems();
const allPosts = getPosts();
const recentPosts = allPosts.slice(0, 5);
const bestPosts = allPosts.slice(0, 5);

const fullTitle = pageTitle ? `${pageTitle}${settings.titleSeparator}${settings.title}` : settings.title;
const canonicalUrl = canonical || new URL(Astro.url.pathname, Astro.site).href;
const faviconSrc = settings.favicon?.src;
const activePath = currentPath || Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  {description && <meta name="description" content={description} />}
  <link rel="canonical" href={canonicalUrl} />
  {faviconSrc && <link rel="icon" type="image/jpeg" href={faviconSrc} />}
  <meta property="og:title" content={fullTitle} />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalUrl} />
  {description && <meta property="og:description" content={description} />}
  {ogImage && <meta property="og:image" content={ogImage} />}
  {ogType === "article" && publishedAt && <meta property="article:published_time" content={publishedAt} />}
  {ogType === "article" && updatedAt && <meta property="article:modified_time" content={updatedAt} />}
  <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
  <meta name="twitter:title" content={fullTitle} />
  {description && <meta name="twitter:description" content={description} />}
  {ogImage && <meta name="twitter:image" content={ogImage} />}
  {settings.googleVerification && <meta name="google-site-verification" content={settings.googleVerification} />}
  {settings.bingVerification && <meta name="msvalidate.01" content={settings.bingVerification} />}
  {config.r2PublicUrl && <link rel="preconnect" href={config.r2PublicUrl} crossorigin />}
  {(fontPreloads as string[]).map((href) => (
    <link rel="preload" as="font" type="font/woff2" href={href} crossorigin />
  ))}
  {themeStyleHref && <link rel="stylesheet" href={themeStyleHref} />}
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>

  <header class="site-header">
    <div class="header-inner">
      <a class="header-brand" href="/">
        {settings.logo?.src ? (
          <img class="header-logo" src={settings.logo.src} alt={settings.logo.alt || settings.title} width={settings.logo.width || 40} height={settings.logo.height || 40} loading="eager" decoding="async" fetchpriority="high" />
        ) : config.headshotUrl ? (
          <img class="header-headshot" src={config.headshotUrl} alt={settings.title} width="40" height="40" loading="eager" decoding="async" fetchpriority="high" sizes="40px" />
        ) : null}
        <span class="header-brand-text">
          <span class="header-site-name">{settings.title}</span>
          {settings.tagline && <span class="header-tagline">{settings.tagline}</span>}
        </span>
      </a>

      <nav class="header-nav" aria-label="Main navigation">
        {menuItems.map((item) => (
          <a href={item.url} class:list={[{ "nav-active": activePath === item.url || (item.url !== "/" && activePath.startsWith(item.url)) }]} target={item.target || undefined}>{item.label}</a>
        ))}
      </nav>

      {config.ctaLabel && config.ctaUrl && (
        <a class="header-cta desktop-only" href={config.ctaUrl}>{config.ctaLabel}</a>
      )}

      <button class="hamburger" aria-label="Toggle menu" aria-expanded="false" id="nav-toggle">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </div>
    <div class="mobile-nav" id="mobile-nav">
      {menuItems.map((item) => (
        <a href={item.url} class:list={[{ "nav-active": activePath === item.url }]} target={item.target || undefined}>{item.label}</a>
      ))}
      {config.ctaLabel && config.ctaUrl && (
        <a class="header-cta" href={config.ctaUrl}>{config.ctaLabel}</a>
      )}
    </div>
  </header>

  <main id="main" class="main-content">
    <slot />
  </main>

  <footer class="site-footer">
    <div class="footer-grid">
      <div class="footer-brand-col">
        {settings.logo?.src && (
          <img class="footer-logo-img" src={settings.logo.src} alt={settings.logo.alt || settings.title} width="36" height="36" loading="lazy" decoding="async" />
        )}
        <a class="footer-brand-name" href="/">{settings.title}</a>
        <p class="footer-blurb">{config.footerBlurb || settings.tagline}</p>
        {(() => {
          const socialLinks = config.social.length > 0 ? config.social : (() => {
            const s = settings.social || {};
            const items: {url: string; label: string; icon: string}[] = [];
            if (s.twitter) items.push({ url: s.twitter, label: "X", icon: '<svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>' });
            if (s.instagram) items.push({ url: s.instagram, label: "Instagram", icon: '<svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>' });
            if (s.linkedin) items.push({ url: s.linkedin, label: "LinkedIn", icon: '<svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>' });
            if (s.facebook) items.push({ url: s.facebook, label: "Facebook", icon: '<svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>' });
            if (s.youtube) items.push({ url: s.youtube, label: "YouTube", icon: '<svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>' });
            return items;
          })();
          return socialLinks.length > 0 && (
            <div class="footer-social">
              {socialLinks.map((s) => (
                <a href={s.url} aria-label={s.label} target="_blank" rel="noopener noreferrer">
                  <Fragment set:html={s.icon} />
                </a>
              ))}
            </div>
          );
        })()}
      </div>
      <div>
        <div class="footer-heading">Recent Posts</div>
        {recentPosts.map((post) => (
          <div class="footer-recent-item">
            <div class="footer-recent-title"><a href={`/posts/${post.slug}`}>{post.title}</a></div>
          </div>
        ))}
      </div>
      <div>
        <div class="footer-heading">Best Posts</div>
        {bestPosts.map((post) => (
          <div class="footer-recent-item">
            <div class="footer-recent-title"><a href={`/posts/${post.slug}`}>{post.title}</a></div>
          </div>
        ))}
      </div>
    </div>
    <div class="footer-bottom">
      <nav class="footer-bottom-nav">
        {menuItems.map((item) => (
          <a href={item.url}>{item.label}</a>
        ))}
      </nav>
    </div>
  </footer>

  <script>
    const toggle = document.getElementById("nav-toggle");
    const nav = document.getElementById("mobile-nav");
    if (toggle && nav) {
      toggle.addEventListener("click", () => {
        const open = nav.classList.toggle("is-open");
        toggle.setAttribute("aria-expanded", String(open));
      });
    }
    // Make post cards fully clickable
    document.querySelectorAll(".post-card").forEach((card) => {
      const link = card.querySelector(".post-card__title a") as HTMLAnchorElement;
      if (link) {
        card.addEventListener("click", (e) => {
          if (!(e.target as HTMLElement).closest("a")) {
            link.click();
          }
        });
      }
    });
  </script>
</body>
</html>
