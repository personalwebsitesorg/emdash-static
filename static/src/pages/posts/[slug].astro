---
import Base from "../../layouts/Base.astro";
import PortableText from "@site/PortableText.astro";
import AuthorBio from "../../components/AuthorBio.astro";
import { getPosts } from "@site/snapshot";

export function getStaticPaths() {
  return getPosts().map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const date = post.publishedAt ? new Date(post.publishedAt).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" }) : null;
const primaryCategory = post.categories[0];
const authorName = post.bylines[0]?.displayName;
---

<Base title={post.title} description={post.excerpt} ogImage={post.featuredImage?.src} ogType="article" publishedAt={post.publishedAt} updatedAt={post.updatedAt}>
  <div class="container section">
    <div class="layout-with-sidebar">
      <article class="prose">
        <nav class="breadcrumbs">
          <a href="/">Home</a>
          <span class="breadcrumb-sep">/</span>
          <a href="/posts">Articles</a>
          <span class="breadcrumb-sep">/</span>
          <span class="breadcrumb-current">{post.title}</span>
        </nav>
        <div class="article-header">
          <h1>{post.title}</h1>
          <div class="article-meta">
            {primaryCategory && <a href={`/category/${primaryCategory.slug}`} class="article-category">{primaryCategory.label}</a>}
            {date && <time datetime={post.publishedAt!}>{date}</time>}
            <span>{post.readingTime} min read</span>
            {authorName && <span>By {authorName}</span>}
          </div>
          {post.excerpt && <p class="article-lead">{post.excerpt}</p>}
        </div>
        {post.featuredImage?.src && (
          <figure class="content-image">
            <img src={post.featuredImage.src} alt={post.featuredImage.alt || post.title} width="760" height="475" loading="eager" decoding="async" fetchpriority="high" sizes="(max-width: 640px) 100vw, 760px" />
          </figure>
        )}
        <PortableText value={post.content} />
      </article>
      <AuthorBio />
    </div>
  </div>
</Base>
