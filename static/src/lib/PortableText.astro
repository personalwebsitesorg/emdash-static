---
/**
 * Renders emdash Portable Text content blocks.
 * Supports: paragraphs, headings (h1-h4), blockquotes, lists, images,
 * and inline marks (bold, italic, underline, links, code).
 */

interface Span {
  _type?: string;
  text?: string;
  marks?: string[];
  children?: Span[];
}

interface ButtonItem {
  _type?: string;
  _key?: string;
  text?: string;
  url?: string;
  style?: string;
}

interface Block {
  _type?: string;
  _key?: string;
  style?: string;
  children?: Span[];
  listItem?: string;
  level?: number;
  // Image blocks
  asset?: { _ref?: string; url?: string };
  alt?: string;
  caption?: string;
  alignment?: string;
  // Mark definitions
  markDefs?: MarkDef[];
  // htmlBlock
  html?: string;
  // button
  text?: string;
  url?: string;
  // buttons container
  buttons?: ButtonItem[];
  layout?: string;
  // pullquote
  citation?: string;
  // code
  code?: string;
  language?: string;
  // gallery
  images?: Block[];
  // columns
  columns?: { content?: Block[] }[];
}

interface MarkDef {
  _key: string;
  _type: string;
  href?: string;
}

interface Props {
  value: unknown[];
}

const { value } = Astro.props;
const blocks = Array.isArray(value) ? (value as Block[]) : [];

function escapeHtml(str: string): string {
  return str
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

// Derive a stable anchor id from heading text. Case-preserving so WordPress-style
// fragments like #Ingredients match <h2 id="Ingredients">Ingredients</h2>; also
// hyphenates whitespace and drops characters outside [A-Za-z0-9_-].
function headingId(text: string): string {
  return text
    .trim()
    .replace(/\s+/g, "-")
    .replace(/[^A-Za-z0-9_-]/g, "");
}

function plainText(block: Block): string {
  return (block.children || []).map((c) => c.text || "").join("");
}

function renderSpan(span: Span, markDefs: MarkDef[] = []): string {
  if (!span.text && span.text !== "") return "";
  let html = escapeHtml(span.text || "");

  const marks = span.marks || [];
  for (const mark of marks) {
    if (mark === "strong") {
      html = `<strong>${html}</strong>`;
    } else if (mark === "em") {
      html = `<em>${html}</em>`;
    } else if (mark === "underline") {
      html = `<u>${html}</u>`;
    } else if (mark === "code") {
      html = `<code>${html}</code>`;
    } else if (mark === "strikethrough") {
      html = `<s>${html}</s>`;
    } else {
      // Check mark definitions (e.g. links)
      const def = markDefs.find((d) => d._key === mark);
      if (def?._type === "link" && def.href) {
        const href = escapeHtml(def.href);
        const isExternal = href.startsWith("http");
        const attrs = isExternal ? ` target="_blank" rel="noopener noreferrer"` : "";
        html = `<a href="${href}"${attrs}>${html}</a>`;
      }
    }
  }
  return html;
}

function renderChildren(block: Block): string {
  return (block.children || [])
    .map((child) => renderSpan(child, block.markDefs || []))
    .join("");
}

// Group consecutive list items into <ul>/<ol>
interface RenderedBlock {
  type: "html";
  html: string;
}

function renderImage(block: Block): string {
  const url = block.asset?.url || block.asset?._ref || "";
  if (!url || !url.startsWith("http")) return "";
  const alt = escapeHtml(block.alt || "");
  const caption = block.caption ? `<figcaption>${escapeHtml(block.caption)}</figcaption>` : "";
  const cls = block.alignment === "wide" ? " content-image--wide" : "";
  return `<figure class="content-image${cls}"><img src="${escapeHtml(url)}" alt="${alt}" loading="lazy" decoding="async" sizes="(max-width: 640px) 100vw, 760px" />${caption}</figure>`;
}

function renderButton(btn: ButtonItem): string {
  const url = btn.url || "#";
  const text = escapeHtml(btn.text || "Button");
  const isExternal = /^https?:/i.test(url);
  const attrs = isExternal ? ` target="_blank" rel="noopener noreferrer"` : "";
  const styleMod = btn.style === "outline" ? " btn--outline" : btn.style === "fill" ? " btn--fill" : "";
  return `<a class="btn btn--primary${styleMod}" href="${escapeHtml(url)}"${attrs}>${text}</a>`;
}

function renderBlock(block: Block): string {
  switch (block._type) {
    case "image":
      return renderImage(block);
    case "htmlBlock":
      return block.html ? `<div class="html-block">${block.html}</div>` : "";
    case "button":
      return `<div class="buttons buttons--vertical">${renderButton(block)}</div>`;
    case "buttons": {
      const items = Array.isArray(block.buttons) ? block.buttons.map(renderButton).join("") : "";
      const layoutCls = block.layout === "horizontal" ? "buttons--horizontal" : "buttons--vertical";
      return items ? `<div class="buttons ${layoutCls}">${items}</div>` : "";
    }
    case "pullquote": {
      const inner = escapeHtml(block.text || "");
      const cite = block.citation ? `<cite>${escapeHtml(block.citation)}</cite>` : "";
      return `<blockquote class="pullquote"><p>${inner}</p>${cite}</blockquote>`;
    }
    case "code": {
      const lang = block.language ? ` class="language-${escapeHtml(block.language)}"` : "";
      return `<pre><code${lang}>${escapeHtml(block.code || "")}</code></pre>`;
    }
    case "gallery": {
      const imgs = Array.isArray(block.images) ? block.images.map(renderImage).join("") : "";
      return imgs ? `<div class="gallery">${imgs}</div>` : "";
    }
    case "columns": {
      const cols = Array.isArray(block.columns)
        ? block.columns
            .map((col) => `<div class="column">${renderBlocks(col.content || [])}</div>`)
            .join("")
        : "";
      return cols ? `<div class="columns">${cols}</div>` : "";
    }
    case "break":
      return "<hr />";
    default:
      return "";
  }
}

function renderBlocks(blocks: Block[]): string {
  const result: string[] = [];
  let i = 0;

  while (i < blocks.length) {
    const block = blocks[i];

    if (block.listItem) {
      const tag = block.listItem === "number" ? "ol" : "ul";
      result.push(`<${tag}>`);
      while (i < blocks.length && blocks[i].listItem) {
        const li = blocks[i];
        result.push(`<li>${renderChildren(li)}</li>`);
        i++;
      }
      result.push(`</${tag}>`);
      continue;
    }

    // Non-text custom block types.
    if (block._type && block._type !== "block") {
      const custom = renderBlock(block);
      if (custom) result.push(custom);
      i++;
      continue;
    }

    const style = block.style || "normal";
    const inner = renderChildren(block);

    if (!inner && style === "normal") {
      i++;
      continue;
    }

    switch (style) {
      case "h1":
      case "h2":
      case "h3":
      case "h4": {
        const id = headingId(plainText(block));
        const idAttr = id ? ` id="${escapeHtml(id)}"` : "";
        result.push(`<${style}${idAttr}>${inner}</${style}>`);
        break;
      }
      case "blockquote": result.push(`<blockquote><p>${inner}</p></blockquote>`); break;
      default: result.push(`<p>${inner}</p>`); break;
    }

    i++;
  }

  return result.join("\n");
}

const html = renderBlocks(blocks);
---

<Fragment set:html={html} />
